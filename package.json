{
  "name": "mharj-jwt-util",
  "version": "0.7.3",
  "description": "JWT util",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "default": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown src/index.ts --minify --sourcemap --format cjs,esm --dts --clean",
    "mocha": "mocha",
    "test-all": "npm run lint && npm run mocha",
    "prepublishOnly": "npm run build",
    "test": "vitest test --run --no-isolate --coverage",
    "azure-test": "vitest test --run --no-isolate --coverage",
    "coverage": "vitest test --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
    "lint": "biome check",
    "validate": "tsc --noEmit --project tsconfig.test.json"
  },
  "repository": "github:mharj/mharj-jwt-util",
  "keywords": [
    "jwt",
    "jsonwebtoken",
    "openid",
    "util"
  ],
  "author": "mharj",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mharj/mharj-jwt-util/issues"
  },
  "homepage": "https://github.com/mharj/mharj-jwt-util#readme",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@avanio/auth-header": "^0.0.5",
    "@avanio/expire-cache": "^0.6.10",
    "@avanio/logger-like": "^0.2.12",
    "@biomejs/biome": "2.4.5",
    "@luolapeikko/cache-types": "^0.0.10",
    "@luolapeikko/ts-common": "^1.1.4",
    "@standard-schema/spec": "^1.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "c8": "^11.0.0",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "tachyon-drive": "^2.0.0",
    "tachyon-drive-node-fs": "^2.0.0",
    "tachyon-expire-cache": "^2.0.0",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@avanio/auth-header": ">= 0.0.1",
    "@avanio/expire-cache": "^0.6.7",
    "@avanio/logger-like": ">= 0.1.0",
    "@luolapeikko/cache-types": ">= 0.0.1",
    "@standard-schema/spec": "^1.1.0",
    "jsonwebtoken": "^9",
    "tachyon-drive": "^2.0.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
